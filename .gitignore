# Secrets - NUNCA commitar
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Cache e dados locais
cache/*
!cache/.gitkeep
cache_test/

# Logs
logs/*
!logs/.gitkeep

# Arquivos temporarios
temp/*
!temp/.gitkeep
*.tmp

# Uploads/testes/documentos sensiveis
temp.pdf
*.pdf
*.docx
*.xlsx

# Banco local
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
.zed/
.vs/

# OS
Thumbs.db
.DS_Store
nul
