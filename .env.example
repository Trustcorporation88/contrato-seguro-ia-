# ================================================================
# CONFIGURAÇÃO - TRUST CORPORATION - Contrato Seguro IA
# ================================================================
# Copie este arquivo para .env e preencha as variáveis

# ================================================================
# GOOGLE OAUTH - Login com conta Google
# ================================================================
# Obtém em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REDIRECT_URI=https://jus.trustcorp.com.br
# Opcional para desenvolvimento local com OAuth:
# ALLOW_LOCALHOST_OAUTH_REDIRECT=true

# ================================================================
# DEEPSEEK - Modelo Primário (Recomendado)
# ================================================================
# API Key do DeepSeek
# Obtém em: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-sua-chave-aqui

# Modelo DeepSeek a usar
# Opções: deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ================================================================
# GEMINI - Google Cloud AI (Fallback)
# ================================================================
# API Key do Google Gemini
# Obtém em: https://ai.google.dev
GEMINI_API_KEY=sua-chave-gemini

# Modelo Gemini a usar
GEMINI_MODEL=gemini-2.5-flash

# ================================================================
# OLLAMA - Ollama Cloud API (Fallback)
# ================================================================
# URL da API Ollama
OLLAMA_API_URL=https://api.ollama.ai/api/generate

# Chave API do Ollama (obtém em https://ollama.ai)
OLLAMA_API_KEY=sua-chave-ollama

# Modelo Ollama a usar
OLLAMA_MODEL=mistral

# ================================================================
# WHATSAPP CLOUD API - Envio de PDF e mensagens
# ================================================================
# Obtém em: https://developers.facebook.com/ (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ================================================================
# EMAIL SMTP - Envio de análises por email
# ================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app
SENDER_EMAIL=seu-email@gmail.com

# ================================================================
# OCR - Reconhecimento de texto em PDFs escaneados
# ================================================================
# Chave gratuita em: https://ocr.space/ocrapi (25,000 requisições/mês)
# Usado como fallback quando Tesseract não está instalado no servidor
OCR_SPACE_API_KEY=sua-chave-ocr-space

# ================================================================
# CONFIGURAÇÕES OPCIONAIS
# ================================================================
REQUEST_TIMEOUT=120
MAX_RETRIES=3
TEMPERATURE=0.7
